# ============================================================================
# Amplify — API - environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.
# ============================================================================

# --- Databases (cloud free tiers — see ADR-018) ---
# Neon Postgres: https://neon.tech (free tier includes dev branch)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/amplify_dev?sslmode=require
# MongoDB Atlas: https://cloud.mongodb.com (M0 free tier)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=amplify_dev
# Upstash Redis: https://upstash.com (free tier)
REDIS_URL=rediss://default:PASSWORD@xxx.upstash.io:6379

# --- LLM providers ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
# Google AI Studio: https://aistudio.google.com — used for Nano Banana 2 image generation
GOOGLE_API_KEY=AIza...

# --- Research ---
TAVILY_API_KEY=tvly-...

# --- Content generation (002-content-generation) ---
# Feature flag for the content generation pipeline (Facebook post variants)
CONTENT_GEN_ENABLED=false
# Object storage for generated 1080x1080 images (S3-compatible)
IMAGE_STORE_BUCKET=amplify-content-dev
IMAGE_STORE_REGION=us-east-1

# --- Observability ---
LANGSMITH_API_KEY=ls-...
LANGSMITH_PROJECT=amplify-dev
LANGSMITH_TRACING=true

# --- Research budgets (override defaults) ---
RESEARCH_BUDGET_QUERIES=8
RESEARCH_BUDGET_SECONDS=60
TAVILY_CACHE_TTL_SECONDS=300
USER_RESEARCH_RATE_LIMIT_PER_HOUR=10