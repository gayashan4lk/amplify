# ============================================================================
# Amplify - WEB — environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.
# ============================================================================

# --- Databases (cloud free tiers — see ADR-018) ---
# Neon Postgres: https://neon.tech (free tier includes dev branch)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/amplify_dev?sslmode=require

# --- Next.js ↔ FastAPI (private network) ---
FASTAPI_INTERNAL_URL=http://localhost:8000

# --- BetterAuth (Next.js) ---
BETTER_AUTH_SECRET=dev-secret-change-me
BETTER_AUTH_URL=http://localhost:3000